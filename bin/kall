#!/usr/bin/env bash
#
# kall — run commands across multiple projects in parallel
# https://github.com/kanetran29/kall
#

VERSION="1.0.0"

# --- workspace root discovery ---
# Walk up from $PWD to find the directory containing .kall
find_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    [ -f "$dir/.kall" ] && echo "$dir" && return 0
    dir="$(dirname "$dir")"
  done
  return 1
}

# --- alias storage (parallel arrays for bash 3.x compat) ---
alias_keys=()
alias_vals=()
repos=()

lookup_alias() {
  for i in "${!alias_keys[@]}"; do
    [ "${alias_keys[$i]}" = "$1" ] && echo "${alias_vals[$i]}" && return 0
  done
  return 1
}

# --- parse .kall config (INI-style) ---
parse_config() {
  repos=()
  alias_keys=()
  alias_vals=()
  local current=""
  [ ! -f "$CONFIG" ] && return
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      current="${BASH_REMATCH[1]}"
      repos+=("$current")
    elif [[ -n "$current" && "$line" =~ ^([^=]+)=(.+)$ ]]; then
      local key="${BASH_REMATCH[1]}" val="${BASH_REMATCH[2]}"
      key="${key#"${key%%[![:space:]]*}"}" ; key="${key%"${key##*[![:space:]]}"}"
      val="${val#"${val%%[![:space:]]*}"}" ; val="${val%"${val##*[![:space:]]}"}"
      alias_keys+=("$current:$key")
      alias_vals+=("$val")
    fi
  done < "$CONFIG"
}

# --- interactive project picker ---
pick_repos() {
  parse_config

  local all_repos=()
  for dir in "$ROOT"/*/; do
    [ -d "$dir/.git" ] && all_repos+=("$(basename "$dir")")
  done

  if [ ${#all_repos[@]} -eq 0 ]; then
    echo "No git repos found in $ROOT"
    exit 1
  fi

  local selected=()
  for i in "${!all_repos[@]}"; do
    if [ -f "$CONFIG" ] && grep -q "^\[${all_repos[$i]}\]$" "$CONFIG"; then
      selected[$i]=1
    else
      selected[$i]=0
    fi
  done

  local cursor=0
  local total=${#all_repos[@]}

  draw() {
    if [ "$1" = "redraw" ]; then
      printf "\033[%dA" $((total + 2))
    fi
    echo "Select projects (space: toggle, enter: confirm)"
    echo
    for i in "${!all_repos[@]}"; do
      local marker="  "
      [ "${selected[$i]}" -eq 1 ] && marker="◆ " || marker="◇ "
      if [ "$i" -eq "$cursor" ]; then
        printf "\033[36m❯ %s%s\033[0m\n" "$marker" "${all_repos[$i]}"
      else
        printf "  %s%s\n" "$marker" "${all_repos[$i]}"
      fi
    done
  }

  printf "\033[?25l"
  trap 'printf "\033[?25h"' EXIT

  draw

  while true; do
    IFS= read -rsn1 key
    case "$key" in
      ' ')
        if [ "${selected[$cursor]}" -eq 1 ]; then
          selected[$cursor]=0
        else
          selected[$cursor]=1
        fi
        draw redraw
        ;;
      $'\x1b')
        read -rsn2 arrow
        case "$arrow" in
          '[A') ((cursor > 0)) && ((cursor--)); draw redraw ;;
          '[B') ((cursor < total - 1)) && ((cursor++)); draw redraw ;;
        esac
        ;;
      '')
        break
        ;;
    esac
  done

  printf "\033[?25h"
  trap - EXIT

  > "$CONFIG"
  local count=0
  for i in "${!all_repos[@]}"; do
    if [ "${selected[$i]}" -eq 1 ]; then
      echo "[${all_repos[$i]}]" >> "$CONFIG"
      for j in "${!alias_keys[@]}"; do
        if [[ "${alias_keys[$j]}" == "${all_repos[$i]}:"* ]]; then
          local aname="${alias_keys[$j]#*:}"
          echo "$aname = ${alias_vals[$j]}" >> "$CONFIG"
        fi
      done
      echo >> "$CONFIG"
      ((count++))
    fi
  done

  echo
  if [ "$count" -eq 0 ]; then
    echo "No projects selected."
    rm -f "$CONFIG"
  else
    echo "Saved $count project(s) to .kall"
  fi
}

# --- set alias in config ---
set_alias() {
  local project="$1" name="$2"
  shift 2
  local cmd="$*"

  if [ ! -f "$CONFIG" ]; then
    echo "No .kall config found. Run 'kall init' first."
    exit 1
  fi

  if ! grep -q "^\[$project\]$" "$CONFIG"; then
    echo "Project '$project' not found in .kall"
    exit 1
  fi

  local tmpfile
  tmpfile=$(mktemp)
  local in_section=0
  local alias_set=0

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      if [ "$in_section" -eq 1 ] && [ "$alias_set" -eq 0 ]; then
        echo "$name = $cmd" >> "$tmpfile"
      fi
      in_section=0
      [[ "${BASH_REMATCH[1]}" == "$project" ]] && in_section=1
      echo "$line" >> "$tmpfile"
    elif [ "$in_section" -eq 1 ] && [[ "$line" =~ ^([^=]+)= ]]; then
      local existing="${BASH_REMATCH[1]}"
      existing="${existing#"${existing%%[![:space:]]*}"}"
      existing="${existing%"${existing##*[![:space:]]}"}"
      if [ "$existing" = "$name" ]; then
        echo "$name = $cmd" >> "$tmpfile"
        alias_set=1
      else
        echo "$line" >> "$tmpfile"
      fi
    else
      echo "$line" >> "$tmpfile"
    fi
  done < "$CONFIG"

  if [ "$in_section" -eq 1 ] && [ "$alias_set" -eq 0 ]; then
    echo "$name = $cmd" >> "$tmpfile"
  fi

  mv "$tmpfile" "$CONFIG"
  echo "Set alias: $project → $name = $cmd"
}

# --- commands ---
case "${1:-}" in
  --version|-v)
    echo "kall $VERSION"
    exit 0
    ;;
  --help|-h|"")
    cat <<'HELP'
kall — run commands across multiple projects in parallel

Usage:
  kall init                          Scan and select projects
  kall config                        Re-select projects
  kall list                          List configured projects
  kall alias <project> <name> <cmd>  Set a command alias
  kall aliases                       List all aliases
  kall <command> [args]              Run across all projects

Options:
  --help, -h        Show this help
  --version, -v     Show version

Aliases map a name to different commands per project:
  kall alias frontend start "yarn start"
  kall alias backend start "flask run"
  kall start   # runs the right command in each project

Config format (.kall):
  [frontend]
  start = yarn start
  test = yarn test

  [backend]
  start = flask run
  test = pytest
HELP
    exit 0
    ;;
  init|config)
    ROOT="$(find_root 2>/dev/null)" || ROOT="$PWD"
    CONFIG="$ROOT/.kall"
    pick_repos
    exit 0
    ;;
  list)
    ROOT="$(find_root)" || { echo "No .kall config found. Run 'kall init' first."; exit 1; }
    CONFIG="$ROOT/.kall"
    parse_config
    for r in "${repos[@]}"; do
      echo "$r"
    done
    exit 0
    ;;
  alias)
    if [ $# -lt 4 ]; then
      echo "Usage: kall alias <project> <name> <command>"
      exit 1
    fi
    ROOT="$(find_root)" || { echo "No .kall config found. Run 'kall init' first."; exit 1; }
    CONFIG="$ROOT/.kall"
    set_alias "$2" "$3" "${@:4}"
    exit 0
    ;;
  aliases)
    ROOT="$(find_root)" || { echo "No .kall config found. Run 'kall init' first."; exit 1; }
    CONFIG="$ROOT/.kall"
    parse_config
    if [ ${#alias_keys[@]} -eq 0 ]; then
      echo "No aliases configured."
      exit 0
    fi
    prev_proj=""
    for i in "${!alias_keys[@]}"; do
      proj="${alias_keys[$i]%%:*}"
      aname="${alias_keys[$i]#*:}"
      if [ "$proj" != "$prev_proj" ]; then
        [ -n "$prev_proj" ] && echo
        echo "[$proj]"
        prev_proj="$proj"
      fi
      echo "  $aname = ${alias_vals[$i]}"
    done
    exit 0
    ;;
esac

# --- run command across projects ---
ROOT="$(find_root)" || { echo "No .kall config found. Run 'kall init' first."; exit 1; }
CONFIG="$ROOT/.kall"
parse_config

if [ ${#repos[@]} -eq 0 ]; then
  echo "No projects in .kall config. Run 'kall init' first."
  exit 1
fi

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
pids=()

for repo in "${repos[@]}"; do
  resolved=$(lookup_alias "$repo:$1")
  if [ $? -eq 0 ]; then
    read -ra alias_parts <<< "$resolved"
    (cd "$ROOT/$repo" && "${alias_parts[@]}" "${@:2}") > "$tmpdir/$repo.out" 2>&1 &
  else
    (cd "$ROOT/$repo" && "$@") > "$tmpdir/$repo.out" 2>&1 &
  fi
  pids+=($!)
done

codes=()
for i in "${!pids[@]}"; do
  wait "${pids[$i]}"
  codes[$i]=$?
done

# --- stacked display ---
term_width=$(tput cols 2>/dev/null || echo 80)
inner=$((term_width - 2))

dim="\033[2m"
cyan="\033[36m"
bold="\033[1m"
reset="\033[0m"
green="\033[32m"
red="\033[31m"

hr_line=$(printf '%0.s─' $(seq 1 $inner))

for i in "${!repos[@]}"; do
  if [ "$i" -eq 0 ]; then
    printf "${dim}┌%s┐${reset}\n" "$hr_line"
  else
    printf "${dim}├%s┤${reset}\n" "$hr_line"
  fi

  if [ "${codes[$i]}" -eq 0 ]; then
    indicator="✓"
    indicator_color="$green"
  else
    indicator="✗"
    indicator_color="$red"
  fi
  label=" ${repos[$i]} $indicator"
  pad_len=$((inner - ${#label}))
  printf "${dim}│${reset}${bold}${cyan} %s${reset} ${indicator_color}%s${reset}%*s${dim}│${reset}\n" "${repos[$i]}" "$indicator" $pad_len ""

  printf "${dim}│%s│${reset}\n" "$hr_line"

  err_color=""
  [ "${codes[$i]}" -ne 0 ] && err_color="$red"
  while IFS= read -r line; do
    stripped=$(printf '%s' "$line" | sed $'s/\033\[[0-9;]*m//g')
    len=${#stripped}
    if ((len + 1 >= inner)); then
      printf "${dim}│${reset} ${err_color}%s${reset}${dim}│${reset}\n" "${line:0:$((inner - 2))}…"
    else
      printf "${dim}│${reset} ${err_color}%s${reset}%*s${dim}│${reset}\n" "$line" $((inner - len - 1)) ""
    fi
  done < "$tmpdir/${repos[$i]}.out"
done

printf "${dim}└%s┘${reset}\n" "$hr_line"

any_failed=0
for code in "${codes[@]}"; do
  [ "$code" -ne 0 ] && any_failed=1
done
exit $any_failed
